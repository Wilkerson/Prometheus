# ============================================================
# Prometheus — Variaveis de ambiente
# ============================================================

# Django
DJANGO_SETTINGS_MODULE=prometheus.settings.dev
SECRET_KEY=troque-por-uma-chave-segura
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=prometheus
DB_USER=prometheus
DB_PASSWORD=prometheus
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Storage — uploads de arquivos
# Providers: "local" (dev), "s3" (AWS S3 / Cloudflare R2), "gcs" (Google Cloud)
STORAGE_PROVIDER=local

# AWS S3 / Cloudflare R2 (quando STORAGE_PROVIDER=s3)
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_BUCKET_NAME=
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ENDPOINT_URL=           # Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com

# Google Cloud Storage (quando STORAGE_PROVIDER=gcs)
# STORAGE_GCS_BUCKET_NAME=
# STORAGE_GCS_PROJECT_ID=
# STORAGE_GCS_CREDENTIALS_FILE=

# Email (dev usa console por padrao, producao configurar SMTP)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=seu-email@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-de-app
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=RUCH Solutions <noreply@ruch.solutions>

# Asaas (Gateway de pagamento)
# Sandbox: https://api-sandbox.asaas.com/v3
# Producao: https://api.asaas.com/v3
# ASAAS_API_KEY=sua-api-key-aqui
# ASAAS_WEBHOOK_TOKEN=token-de-seguranca-do-webhook
# ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# Sistema externo (integracao de clientes em processamento)
SISTEMA_EXTERNO_URL=
SISTEMA_EXTERNO_API_KEY=

# ============================================================
# Producao (ajustar ao fazer deploy)
# ============================================================
# DJANGO_SETTINGS_MODULE=prometheus.settings.production
# ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br
# SECURE_SSL_REDIRECT=True
# CSRF_TRUSTED_ORIGINS=https://seudominio.com.br
# SENTRY_DSN=https://xxx@sentry.io/yyy
