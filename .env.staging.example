# ============================================================
# Prometheus — Staging (staging.ruch.solutions)
# ============================================================

# Django
DJANGO_SETTINGS_MODULE=prometheus.settings.staging
SECRET_KEY=troque-por-uma-chave-segura-staging
ALLOWED_HOSTS=staging.ruch.solutions

# Database (banco separado do producao!)
DB_NAME=prometheus_staging
DB_USER=prometheus
DB_PASSWORD=troque-por-senha-segura
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# CORS
CORS_ALLOWED_ORIGINS=https://staging.ruch.solutions

# Seguranca
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=https://staging.ruch.solutions

# Storage — local em staging
STORAGE_PROVIDER=local

# Email — console em staging (emails aparecem no log do container)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=RUCH Solutions <noreply@staging.ruch.solutions>

# Asaas — SEMPRE sandbox em staging!
ASAAS_API_KEY=sua-api-key-sandbox
ASAAS_WEBHOOK_TOKEN=token-webhook-staging
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# Sentry (opcional)
# SENTRY_DSN=
