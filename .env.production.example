# ============================================================
# Prometheus — Producao (ruch.solutions)
# ============================================================

# Django
DJANGO_SETTINGS_MODULE=prometheus.settings.production
SECRET_KEY=troque-por-uma-chave-segura-producao
ALLOWED_HOSTS=ruch.solutions,www.ruch.solutions

# Database
DB_NAME=prometheus
DB_USER=prometheus
DB_PASSWORD=troque-por-senha-segura-producao
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# CORS
CORS_ALLOWED_ORIGINS=https://ruch.solutions

# Seguranca
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=https://ruch.solutions,https://www.ruch.solutions

# Storage — S3 / Cloudflare R2
STORAGE_PROVIDER=s3
STORAGE_S3_ACCESS_KEY=sua-access-key
STORAGE_S3_SECRET_KEY=sua-secret-key
STORAGE_S3_BUCKET_NAME=prometheus-uploads
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT_URL=https://account-id.r2.cloudflarestorage.com

# Email — SMTP producao
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu-email@ruch.solutions
EMAIL_HOST_PASSWORD=sua-senha-de-app
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=RUCH Solutions <noreply@ruch.solutions>

# Asaas — PRODUCAO
ASAAS_API_KEY=sua-api-key-producao
ASAAS_WEBHOOK_TOKEN=token-webhook-producao
ASAAS_BASE_URL=https://api.asaas.com/v3

# Sentry
SENTRY_DSN=https://xxx@sentry.io/yyy
