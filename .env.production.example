# ============================================================
# Prometheus — Variaveis de producao (ruch.solutions)
# ============================================================
# Copie este arquivo e ajuste os valores no Easypanel

DJANGO_SETTINGS_MODULE=prometheus.settings.production
SECRET_KEY=GERE_UMA_CHAVE_SEGURA_AQUI
ALLOWED_HOSTS=ruch.solutions,www.ruch.solutions
CSRF_TRUSTED_ORIGINS=https://ruch.solutions,https://www.ruch.solutions
CORS_ALLOWED_ORIGINS=https://ruch.solutions

# Database (usar host interno do Easypanel)
DB_NAME=prometheus
DB_USER=prometheus
DB_PASSWORD=SENHA_SEGURA_AQUI
DB_HOST=prometheus-db
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Redis (usar host interno do Easypanel)
REDIS_URL=redis://prometheus-redis:6379/0
CELERY_BROKER_URL=redis://prometheus-redis:6379/1

# Seguranca
SECURE_SSL_REDIRECT=True

# Storage (configurar quando tiver bucket)
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_BUCKET_NAME=
# STORAGE_S3_ENDPOINT_URL=

# Sistema externo
SISTEMA_EXTERNO_URL=
SISTEMA_EXTERNO_API_KEY=

# Sentry (opcional)
SENTRY_DSN=
